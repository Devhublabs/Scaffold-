# Copy this file to `.env` to override the docker-compose development defaults.
# Everything here is OPTIONAL — the stack boots without a .env file.

# Secret used to sign JWTs in backend-node. Change this for anything non-local.
JWT_SECRET=dev-secret-change-me

# MongoDB connection string used by backend-node.
# Inside docker-compose, "mongo" is the service hostname.
MONGO_URI=mongodb://mongo:27017/scaffold
DAILY_API_KEY=your_daily_api_key_here
